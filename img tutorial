<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AOI • Waifu Gallery</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700&display=swap');

    :root {
      --purple: #a855f7;
      --dark: #0a0a0a;
      --darker: #050505;
      --light-purple: #c084fc;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(135deg, var(--dark) 0%, #1a0033 100%);
      color: #e0e0e0;
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: radial-gradient(circle at 50% 30%, rgba(168, 85, 247, 0.15) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }

    .container {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 1100px;
      padding: 20px;
      text-align: center;
    }

    header {
      margin-bottom: 30px;
    }

    h1 {
      font-family: 'Playfair Display', serif;
      font-size: 3.8rem;
      background: linear-gradient(90deg, #c084fc, #e0bbff, #a855f7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 0 40px rgba(168, 85, 247, 0.6);
      margin-bottom: 8px;
    }

    .subtitle {
      font-size: 1.15rem;
      color: #b3b3b3;
      letter-spacing: 3px;
      text-transform: uppercase;
    }

    .card {
      background: rgba(10, 10, 10, 0.88);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.7),
                  0 0 90px rgba(168, 85, 247, 0.3);
      border: 1px solid rgba(168, 85, 247, 0.35);
      transition: all 0.4s ease;
    }

    .card:hover {
      transform: translateY(-12px);
      box-shadow: 0 30px 90px rgba(0, 0, 0, 0.8),
                  0 0 120px rgba(168, 85, 247, 0.45);
    }

    .image-container {
      position: relative;
      height: 640px;
      background: #000;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    #waifuImage {
      max-height: 100%;
      max-width: 100%;
      object-fit: contain;
      transition: transform 0.7s ease;
    }

    .card:hover #waifuImage {
      transform: scale(1.04);
    }

    .loading {
      position: absolute;
      color: var(--purple);
      font-size: 1.15rem;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .spinner {
      width: 32px;
      height: 32px;
      border: 4px solid rgba(168, 85, 247, 0.2);
      border-top-color: var(--purple);
      border-radius: 50%;
      animation: spin 0.9s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .btn {
      margin-top: 25px;
      padding: 15px 40px;
      background: linear-gradient(90deg, #7e22ce, #a855f7);
      color: white;
      border: none;
      border-radius: 50px;
      font-weight: 600;
      font-size: 1.1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 10px 30px rgba(168, 85, 247, 0.45);
    }

    .btn:hover {
      transform: translateY(-4px);
      box-shadow: 0 15px 40px rgba(168, 85, 247, 0.6);
    }

    .footer {
      margin-top: 30px;
      font-size: 0.95rem;
      color: #777;
    }

    .footer a {
      color: #c084fc;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>AOI</h1>
      <p class="subtitle">Waifu Random Gallery</p>
    </header>

    <div class="card">
      <div class="image-container">
        <div id="loading" class="loading">
          <div class="spinner"></div>
          <span>Cargando waifu aleatoria...</span>
        </div>
        <img id="waifuImage" src="" alt="Waifu Aleatoria" style="display: none;">
      </div>
    </div>

    <button class="btn" onclick="loadRandomImage()">Nueva Waifu Aleatoria</button>

    <div class="footer">
      Powered by <a href="https://waifu.pics" target="_blank">waifu.pics API</a> • Tema Negro & Morado
    </div>
  </div>

  <script>
    const img = document.getElementById('waifuImage');
    const loading = document.getElementById('loading');

    async function loadRandomImage() {
      loading.style.display = 'flex';
      img.style.display = 'none';

      try {
        const response = await fetch('https://api.waifu.pics/sfw/waifu');
        
        if (!response.ok) throw new Error('Error al conectar con la API');

        const data = await response.json();
        const imageUrl = data.url;   // La API devuelve directamente "url"

        img.onload = () => {
          loading.style.display = 'none';
          img.style.display = 'block';
        };

        img.src = imageUrl;

      } catch (error) {
        console.error(error);
        loading.innerHTML = `<span style="color:#f87171;">Error al cargar la imagen.<br>Inténtalo de nuevo.</span>`;
      }
    }

    // Cargar imagen automáticamente al abrir la página
    window.onload = loadRandomImage;
  </script>
</body>
</html>
